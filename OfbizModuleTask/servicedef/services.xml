    <service name="createPersonAndParty" engine="groovy"
             location="component://relationshipmgr/GroovyScripts/Party/CreatePersonAndParty.groovy"
             invoke="" auth="true">
        <description>Create Party + Person in one transaction</description>
        <!-- Party fields -->
        <attribute name="partyTypeId"  type="String" mode="IN" optional="true"  default-value="PERSON"/>
        <attribute name="statusId"     type="String" mode="IN" optional="true"/>
        <attribute name="description"  type="String" mode="IN" optional="true"/>

        <!-- Person fields -->
        <attribute name="salutation"   type="String" mode="IN" optional="true"/>
        <attribute name="firstName"    type="String" mode="IN" optional="false"/>
        <attribute name="middleName"   type="String" mode="IN" optional="true"/>
        <attribute name="lastName"     type="String" mode="IN" optional="false"/>
        <attribute name="birthDate"    type="java.sql.Date" mode="IN" optional="true"/>
        <attribute name="height"       type="Double" mode="IN" optional="true"/>
        <attribute name="weight"       type="Double" mode="IN" optional="true"/>

        <!-- CHANGED: Replaced overrides with standard attributes -->
        <attribute name="personalTitle" type="String" mode="IN" optional="false"/>
        <attribute name="suffix"        type="String" mode="IN" optional="false"/>

        <!-- Returned to caller -->
        <attribute name="partyId"      type="String" mode="OUT" optional="false"/>
    </service>

