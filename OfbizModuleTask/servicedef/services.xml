        <attribute name="numEmployee"     type="Long"   mode="IN" optional="true"/>
        <attribute name="annualRevenue"   type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="partyId"         type="String" mode="OUT" optional="false"/>
    </service>

