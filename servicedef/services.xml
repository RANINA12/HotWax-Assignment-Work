<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>Ordermgr Services</description>
    <vendor>
        
    </vendor>
    <version>1.0</version>

    <service name="noSyntaxError" engine="interface">
        <description>
            Dummy service to prevent empty files and syntax error - Remove when the 1st real service will be added here 
        </description>
    </service>

    <service name="CreateOrderHeader" default-entity-name="OrderHeaderNick" engine="entity-auto" invoke="create" auth="true">
        <description>Create Order Header</description>
        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderId" mode="IN" optional="true"/>
    </service>

    <service name="CreateOrderItem" default-entity-name="OrderItemNick" engine="entity-auto" invoke="create" auth="true">

        <description>Create Order Item</description>
        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderId" mode="IN" optional="false"/>
        <override name="orderItemSeqId" mode="IN" optional="true"/>
    </service>

    <service name="CreateOrderRole" default-entity-name="OrderRoleNick" engine="entity-auto" invoke="create" auth="true">

        <description>Create Order Role</description>

        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderId" mode="IN" optional="false"/>
        <override name="roleTypeId" mode="IN" optional="false"/>
        <override name="partyId" mode="IN" optional="false"/>
    </service>

    <service name="CreateOrderAdjustment" default-entity-name="OrderOrderAdjustmentNick" engine="entity-auto" invoke="create" auth="true">

        <description>Create Order Adjustment</description>

        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderAdjustmentId" mode="IN" optional="false"/>
    </service>

    <service name="CreateOrderPaymentPreference" default-entity-name="OrderPaymentPreferenceNick" engine="entity-auto" invoke="create" auth="true">

        <description>Create Order Payment Preference</description>

        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderPaymentPreferenceId" mode="IN" optional="false"/>
    </service>

    <service name="CreateOrderContactMech" default-entity-name="OrderContactMechNick" engine="entity-auto" invoke="create" auth="true">

        <description>Create Order Contact Mech</description>

        <auto-attributes include="pk" mode="OUT" optional="true"/>
        <auto-attributes include="nonpk" mode="IN" optional="true"/>

        <override name="orderId" mode="IN" optional="false"/>
        <override name="contactMechId" mode="IN" optional="false"/>
        <override name="orderItemSeqId" mode="IN" optional="true"/>
        <override name="contactMechPurposeId" mode="IN" optional="false"/>
    </service>

</services>