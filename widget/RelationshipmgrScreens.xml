<screens xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Screen" xsi:schemaLocation="http://ofbiz.apache.org/Widget-Screen http://ofbiz.apache.org/dtds/widget-screen.xsd">

        <screen name="main">
            <section>
                <actions>
                    <set field="headerItem" value="main"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">

                            <screenlet title="Add Person">
                                <include-form name="AddPerson"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>

                            <screenlet title="Add Organisation (Party Group)">
                                <include-form name="AddPartyGroup"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>

                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="PartyRole">
            <section>
                <actions>
                    <set field="headerItem" value="PartyRole"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Party Role">
                                <include-form name="AddPartyRole"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="PartyRelationship">
            <section>
                <actions>
                    <set field="headerItem" value="PartyRelationship"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Party Relationship">
                                <include-form name="AddPartyRelationship"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="PartyClassification">
            <section>
                <actions>
                    <set field="headerItem" value="PartyClassification"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Party Classification">
                                <include-form name="AddPartyClassification"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="AddEmail">
            <section>
                <actions>
                    <set field="headerItem" value="AddEmail"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Email Address">
                                <include-form name="AddEmailContactMech"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="AddTelecomNumber">
            <section>
                <actions>
                    <set field="headerItem" value="AddTelecomNumber"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Telecom Number">
                                <include-form name="AddTelecomNumber"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="AddPostalAddress">
            <section>
                <actions>
                    <set field="headerItem" value="AddPostalAddress"/>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">
                            <screenlet title="Add Postal Address">
                                <include-form name="AddPostalAddress"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>
                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

        <screen name="PartyContactMech">
            <section>
                <actions>
                    <set field="headerItem" value="PartyContactMech"/>
                    <!-- Load list for the partyId passed in parameters -->
                    <entity-and entity-name="PartyContactMech"
                                list="partyContactMechList">
                        <field-map field-name="partyId" from-field="parameters.partyId"/>
                    </entity-and>
                </actions>
                <widgets>
                    <decorator-screen name="main-decorator"
                                      location="${parameters.mainDecoratorLocation}">
                        <decorator-section name="body">

                            <screenlet title="Link Contact Mechanism to Party">
                                <include-form name="AddPartyContactMech"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>

                            <screenlet title="Assign Purpose to Party Contact Mechanism">
                                <include-form name="AddPartyContactMechPurpose"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>

                            <screenlet title="Existing Contact Mechanisms">
                                <include-form name="ListPartyContactMechs"
                                              location="component://relationshipmgr/widget/RelationshipmgrForms.xml"/>
                            </screenlet>

                        </decorator-section>
                    </decorator-screen>
                </widgets>
            </section>
        </screen>

    </screens>
